# Copy to `.env` for local dev (gitignored). Do NOT commit real secrets.
#
# Vite env file precedence (each overrides the previous):
#   .env                            always loaded, safe to commit (no secrets)
#   .env.development                loaded on `npm run dev`, safe to commit
#   .env.production                 loaded on `npm run build` (gitignored here)
#   .env.local                      local override for all modes, gitignored
#   .env.development.local          dev local override, gitignored
#   .env.production.local           prod local override, gitignored

# ---- Local dev (.env / .env.development) -----------------------------------
# Leave VITE_BACKEND_URL and VITE_SOCKET_URL EMPTY or unset in dev — Vite's
# proxy (vite.config.js) forwards /api/* and /socket.io/* to the local backend.

VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_STRIPE_KEY_ID=<your-stripe-test-publishable-key>

# ---- Production (set in Vercel Project Settings, NOT committed) ------------
# VITE_BACKEND_URL=https://xxxxxxxx.execute-api.ap-south-1.amazonaws.com
# VITE_SOCKET_URL=https://your-socket-host.onrender.com
# VITE_GOOGLE_CLIENT_ID=<same as above>
# VITE_STRIPE_KEY_ID=pk_live_xxxxxxxxxxxxxxxxxxxxxxxx
