# Copy to `.env` for local dev (gitignored).
#
# Production: set these as GitHub repository secrets — the deploy workflow
# (.github/workflows/deploy-backend.yml) forwards them into the Lambda env
# via serverless.yml. `.env` itself is not deployed to Lambda.

NODE_ENV=development
PORT=3000

# Mongo Atlas connection string WITHOUT a trailing /dbname.
# The code appends `/Click&Care` (see config/mongodb.js).
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net

JWT_SECRET=some-long-random-string

# Frontend / admin origins (used by CORS + Stripe return URLs)
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5176

# Cloudinary
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET_KEY=

# Stripe (format: sk_test_... for test mode, sk_live_... for production)
STRIPE_SECRET_KEY=

# SMTP (nodemailer)
EMAIL_USER=
EMAIL_PASSWORD=
